[Unit]
Description=Valorant Shop Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=azureuser
WorkingDirectory=/home/azureuser/valorant-shop-bot
EnvironmentFile=/home/azureuser/valorant-shop-bot/config.env
ExecStart=/usr/bin/python3 -u bot.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
