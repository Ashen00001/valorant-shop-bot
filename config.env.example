# Copy this file to config.env and fill in your values.
# config.env is gitignored — your credentials stay local.

# Discord bot token — from Discord Developer Portal > Your App > Bot > Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord channel ID — right-click the channel > Copy Channel ID (needs Developer Mode on)
DISCORD_CHANNEL_ID=your_channel_id_here

# Valorant region: na, eu, ap, kr, br, latam
RIOT_REGION=na

# Optional — override defaults if you want
# BOT_PREFIX=!       # command prefix (default: !)
# WAIT_MINUTES=30
# RECHECK_HOURS=3
